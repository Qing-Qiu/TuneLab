:host {
  display: block;
}

.tab-bar-shell {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: 18rpx;
  height: 112rpx;
  box-sizing: border-box;
  padding: 10rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  background: rgba(9, 14, 13, 0.9);
  box-shadow: 0 -10rpx 28rpx rgba(0, 0, 0, 0.22);
  backdrop-filter: blur(18rpx);
}

.tab-item {
  position: relative;
  min-width: 0;
  flex: 1;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border-radius: 16rpx;
  color: rgba(244, 247, 246, 0.58);
}

.tab-item-active {
  color: #12201d;
  background: linear-gradient(135deg, #f1a36c 0%, #ffd3a5 100%);
}

.tab-icon-shell {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.08);
}

.tab-item-active .tab-icon-shell {
  background: rgba(18, 32, 29, 0.12);
}

.tab-icon {
  width: 34rpx;
  height: 34rpx;
  opacity: 0.76;
}

.tab-item-active .tab-icon {
  opacity: 1;
}

.tab-label {
  display: block;
  font-size: 25rpx;
  line-height: 1.2;
  font-weight: 800;
  color: inherit;
}
