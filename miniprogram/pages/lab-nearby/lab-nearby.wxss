page {
  background: #0f1715;
  color: #f4f7f6;
}

.mixtape-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 28rpx 56rpx;
  background:
    radial-gradient(circle at 82% 0%, rgba(125, 215, 194, 0.16), transparent 30%),
    radial-gradient(circle at 8% 10%, rgba(241, 163, 108, 0.12), transparent 28%),
    linear-gradient(180deg, #10201d 0%, #0f1715 72%);
}

.mixtape-hero {
  min-height: 188rpx;
  box-sizing: border-box;
  padding: 30rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.08), rgba(63, 133, 119, 0.18)),
    #111c19;
}

.hero-copy {
  min-width: 0;
  flex: 1;
}

.eyebrow,
.hero-title,
.hero-subtitle,
.stat-value,
.stat-label,
.section-kicker,
.section-title,
.place-title,
.place-desc,
.mood-chip,
.selected-title,
.selected-artist,
.song-result-title,
.song-result-artist,
.entry-place,
.entry-time,
.entry-song,
.entry-artist,
.entry-note,
.entry-author,
.empty-title,
.empty-desc {
  display: block;
}

.eyebrow {
  font-size: 22rpx;
  line-height: 1.3;
  font-weight: 800;
  color: rgba(244, 247, 246, 0.62);
}

.hero-title {
  margin-top: 10rpx;
  font-size: 48rpx;
  line-height: 1.08;
  font-weight: 800;
  color: #ffffff;
}

.hero-subtitle {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.45;
  color: rgba(244, 247, 246, 0.78);
}

.hero-icon {
  width: 116rpx;
  height: 116rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: rgba(9, 14, 13, 0.42);
}

.stat-strip {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: 0.8fr 0.8fr 1.4fr;
  gap: 12rpx;
}

.stat-item {
  min-width: 0;
  min-height: 102rpx;
  box-sizing: border-box;
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  background: rgba(255, 255, 255, 0.06);
}

.stat-value {
  font-size: 34rpx;
  line-height: 1.1;
  font-weight: 900;
  color: #f1a36c;
}

.stat-value-small {
  font-size: 27rpx;
  color: #7dd7c2;
  word-break: break-all;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.2;
  color: rgba(228, 236, 233, 0.68);
  font-weight: 800;
}

.map-shell {
  margin-top: 20rpx;
  height: 390rpx;
  overflow: hidden;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  background: #172421;
}

.cloud-warning {
  margin-top: 16rpx;
  min-height: 62rpx;
  box-sizing: border-box;
  padding: 12rpx 16rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  border-radius: 14rpx;
  background: rgba(241, 163, 108, 0.12);
  color: rgba(244, 247, 246, 0.76);
  font-size: 22rpx;
  line-height: 1.35;
}

.mixtape-map {
  width: 100%;
  height: 100%;
}

.editor-panel {
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  background: rgba(255, 255, 255, 0.06);
}

.section-header {
  margin-top: 0;
}

.list-header {
  margin-top: 28rpx;
}

.section-kicker {
  font-size: 22rpx;
  line-height: 1.3;
  color: rgba(244, 247, 246, 0.62);
  font-weight: 800;
}

.section-title {
  margin-top: 6rpx;
  font-size: 34rpx;
  line-height: 1.2;
  color: #ffffff;
  font-weight: 800;
}

.place-picker {
  margin-top: 18rpx;
  min-height: 124rpx;
  box-sizing: border-box;
  padding: 18rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  border-radius: 14rpx;
  background: rgba(9, 14, 13, 0.42);
}

.place-copy {
  min-width: 0;
  flex: 1;
}

.place-title {
  font-size: 30rpx;
  line-height: 1.24;
  color: #ffffff;
  font-weight: 800;
  word-break: break-all;
}

.place-desc {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.36;
  color: rgba(228, 236, 233, 0.66);
  word-break: break-all;
}

.map-mini-btn,
.action-btn,
.save-btn,
.clear-btn,
.entry-icon-btn,
.entry-like-btn,
.song-search-btn,
.export-btn {
  margin: 0;
  padding: 0;
  border: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border-radius: 14rpx;
  font-weight: 800;
}

.map-mini-btn::after,
.action-btn::after,
.save-btn::after,
.clear-btn::after,
.entry-icon-btn::after,
.entry-like-btn::after,
.song-search-btn::after,
.export-btn::after {
  border: 0;
}

.map-mini-btn {
  width: 66rpx;
  height: 66rpx;
  flex-shrink: 0;
  background: #7dd7c2;
}

.action-row {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.action-btn {
  height: 74rpx;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #f4f7f6;
  font-size: 25rpx;
}

.action-btn-primary {
  background: #f1a36c;
  color: #12201d;
}

.form-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 12rpx;
}

.song-search-card {
  margin-top: 18rpx;
  padding: 14rpx;
  border-radius: 14rpx;
  background: #0f1715;
}

.song-search-box {
  min-height: 72rpx;
  padding: 0 10rpx 0 16rpx;
  box-sizing: border-box;
  display: grid;
  grid-template-columns: 32rpx 1fr 120rpx;
  align-items: center;
  gap: 10rpx;
  border-radius: 14rpx;
  background: #17231f;
}

.song-search-input {
  min-width: 0;
  height: 72rpx;
  color: #ffffff;
  font-size: 25rpx;
}

.song-search-btn {
  height: 56rpx;
  border-radius: 12rpx;
  background: #7dd7c2;
  color: #10201d;
  font-size: 23rpx;
}

.selected-song,
.song-result-row,
.entry-song-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.selected-song {
  margin-top: 12rpx;
  padding: 12rpx;
  border-radius: 12rpx;
  background: rgba(125, 215, 194, 0.1);
}

.selected-cover,
.song-result-cover,
.entry-cover {
  flex-shrink: 0;
  border-radius: 10rpx;
  background: #17231f;
}

.selected-cover,
.song-result-cover {
  width: 68rpx;
  height: 68rpx;
}

.selected-copy,
.song-result-copy,
.entry-song-copy {
  min-width: 0;
  flex: 1;
}

.selected-title,
.song-result-title {
  color: #ffffff;
  font-size: 25rpx;
  line-height: 1.24;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.selected-artist,
.song-result-artist {
  margin-top: 5rpx;
  color: rgba(228, 236, 233, 0.58);
  font-size: 21rpx;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.song-result-list {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.song-result-row {
  min-height: 86rpx;
  padding: 10rpx;
  box-sizing: border-box;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.055);
}

.song-result-row-active {
  background: rgba(125, 215, 194, 0.16);
}

.text-input {
  min-width: 0;
  height: 78rpx;
  box-sizing: border-box;
  padding: 0 18rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #ffffff;
  font-size: 25rpx;
  line-height: 78rpx;
}

.solo-input {
  margin-top: 12rpx;
  width: 100%;
}

.input-placeholder {
  color: rgba(228, 236, 233, 0.42);
}

.mood-row {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
}

.mood-chip {
  height: 62rpx;
  box-sizing: border-box;
  padding: 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.07);
  color: rgba(244, 247, 246, 0.76);
  font-size: 22rpx;
  line-height: 1;
  font-weight: 800;
}

.mood-chip-active {
  background: #7dd7c2;
  color: #10201d;
}

.note-input {
  margin-top: 16rpx;
  width: 100%;
  height: 150rpx;
  box-sizing: border-box;
  padding: 18rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #ffffff;
  font-size: 25rpx;
  line-height: 1.42;
}

.save-row {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: 1fr 150rpx;
  gap: 12rpx;
}

.save-btn,
.clear-btn,
.export-btn {
  height: 72rpx;
  font-size: 25rpx;
}

.save-btn {
  background: #7dd7c2;
  color: #10201d;
}

.clear-btn {
  background: rgba(255, 255, 255, 0.08);
  color: #f4f7f6;
}

.entry-list {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.entry-card {
  min-height: 156rpx;
  box-sizing: border-box;
  padding: 18rpx;
  display: flex;
  align-items: stretch;
  gap: 14rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  background: rgba(255, 255, 255, 0.06);
}

.entry-card-hover,
.entry-card-active {
  border-color: rgba(125, 215, 194, 0.34);
  background: rgba(125, 215, 194, 0.1);
}

.entry-main {
  min-width: 0;
  flex: 1;
}

.entry-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.entry-place {
  min-width: 0;
  flex: 1;
  font-size: 29rpx;
  line-height: 1.24;
  color: #ffffff;
  font-weight: 900;
  word-break: break-all;
}

.entry-time {
  flex-shrink: 0;
  font-size: 21rpx;
  line-height: 1.3;
  color: rgba(228, 236, 233, 0.52);
  font-weight: 800;
}

.entry-song-row {
  margin-top: 9rpx;
}

.entry-cover {
  width: 58rpx;
  height: 58rpx;
}

.entry-song {
  font-size: 25rpx;
  line-height: 1.28;
  color: #f1a36c;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.entry-artist {
  margin-top: 4rpx;
  font-size: 20rpx;
  line-height: 1.2;
  color: rgba(228, 236, 233, 0.54);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.entry-playlist {
  display: block;
  margin-top: 8rpx;
  padding: 7rpx 10rpx;
  max-width: 100%;
  box-sizing: border-box;
  border-radius: 10rpx;
  background: rgba(125, 215, 194, 0.12);
  color: #7dd7c2;
  font-size: 21rpx;
  line-height: 1.25;
  font-weight: 800;
  word-break: break-all;
}

.entry-note {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.36;
  color: rgba(228, 236, 233, 0.68);
  word-break: break-all;
}

.entry-author {
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.2;
  color: rgba(125, 215, 194, 0.78);
  font-weight: 800;
}

.entry-actions {
  width: 76rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.entry-icon-btn {
  width: 64rpx;
  height: 44rpx;
  background: #7dd7c2;
}

.entry-like-btn {
  width: 76rpx;
  height: 54rpx;
  gap: 5rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #f4f7f6;
  font-size: 21rpx;
}

.entry-like-btn-done {
  background: #7dd7c2;
  color: #12201d;
}

.entry-icon-btn-play {
  background: #f1a36c;
}

.entry-icon-btn-dark {
  background: rgba(255, 255, 255, 0.08);
}

.entry-icon-btn-danger {
  background: #d75f50;
}

.export-btn {
  margin-top: 4rpx;
  background: rgba(241, 163, 108, 0.14);
  color: #f1a36c;
}

.empty-state {
  margin-top: 18rpx;
  min-height: 250rpx;
  box-sizing: border-box;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  background: rgba(255, 255, 255, 0.05);
}

.empty-title {
  margin-top: 16rpx;
  font-size: 29rpx;
  line-height: 1.24;
  color: #ffffff;
  font-weight: 800;
}

.empty-desc {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.36;
  color: rgba(228, 236, 233, 0.64);
  text-align: center;
}

.playlist-bind-panel {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 14rpx;
  background: rgba(9, 14, 13, 0.32);
}

.playlist-bind-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.playlist-bind-title,
.playlist-bind-desc,
.playlist-bind-count {
  display: block;
}

.playlist-bind-title {
  flex-shrink: 0;
  font-size: 24rpx;
  line-height: 1.3;
  color: #ffffff;
  font-weight: 900;
}

.playlist-bind-desc {
  min-width: 0;
  flex: 1;
  font-size: 22rpx;
  line-height: 1.32;
  color: rgba(228, 236, 233, 0.58);
  text-align: right;
  word-break: break-all;
}

.playlist-bind-scroll {
  margin-top: 14rpx;
  white-space: nowrap;
}

.playlist-bind-row {
  display: inline-flex;
  gap: 10rpx;
  padding-right: 4rpx;
}

.playlist-bind-chip {
  min-width: 120rpx;
  height: 64rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.07);
  color: rgba(244, 247, 246, 0.76);
  font-size: 23rpx;
  line-height: 1;
  font-weight: 800;
}

.playlist-bind-chip-active {
  background: #f1a36c;
  color: #12201d;
}

.playlist-bind-count {
  font-size: 19rpx;
  color: inherit;
  opacity: 0.68;
}

/* Cleaner lab surface */
.mixtape-page {
  background: #0f1715;
}

.mixtape-hero,
.editor-panel,
.entry-card,
.empty-state,
.level-panel,
.daily-panel {
  background: #121c1a;
}

.mixtape-hero {
  min-height: 156rpx;
  padding: 24rpx;
}

.hero-title {
  font-size: 42rpx;
}

.hero-subtitle {
  margin-top: 10rpx;
  color: rgba(244, 247, 246, 0.66);
}

.hero-icon {
  width: 88rpx;
  height: 88rpx;
  background: #17231f;
}

.stat-strip {
  margin-top: 14rpx;
}

.stat-item,
.editor-panel,
.entry-card,
.empty-state,
.playlist-bind-panel {
  border-radius: 16rpx;
  background: #121c1a;
}

.map-shell {
  height: 310rpx;
  margin-top: 14rpx;
}

.editor-panel {
  margin-top: 14rpx;
  padding: 20rpx;
}

.place-picker {
  background: #0f1715;
}

.text-input,
.note-input,
.mood-chip,
.clear-btn,
.entry-icon-btn-dark {
  background: #17231f;
}

.entry-list {
  gap: 12rpx;
}
