page {
  background: #0f1715;
  color: #f4f7f6;
}

.schulte-page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 28rpx 28rpx 48rpx;
  background: #0f1715;
}

.tool-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.head-actions {
  display: flex;
  flex-shrink: 0;
  gap: 12rpx;
}

.kicker,
.title,
.subtitle,
.metric-value,
.metric-label,
.hint,
.mistakes {
  display: block;
}

.kicker {
  font-size: 21rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #7dd7c2;
  letter-spacing: 0;
}

.title {
  margin-top: 8rpx;
  font-size: 46rpx;
  line-height: 1.12;
  font-weight: 900;
  color: #ffffff;
}

.subtitle {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.45;
  color: rgba(244, 247, 246, 0.66);
}

.icon-btn {
  width: 76rpx;
  height: 76rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: #182421;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.icon-btn::after,
.size-tab::after,
.profile-btn::after,
.record-refresh::after,
.modal-close::after {
  border: 0;
}

.metrics {
  margin-top: 28rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.metric {
  min-height: 104rpx;
  box-sizing: border-box;
  padding: 16rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: #141f1d;
  border: 1rpx solid rgba(255, 255, 255, 0.07);
}

.metric-value {
  font-size: 34rpx;
  line-height: 1.12;
  font-weight: 900;
  color: #f1a36c;
}

.metric-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.2;
  color: rgba(244, 247, 246, 0.55);
}

.size-tabs {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.size-tab {
  min-height: 72rpx;
  padding: 0;
  border-radius: 14rpx;
  background: #14201d;
  color: rgba(244, 247, 246, 0.72);
  font-size: 25rpx;
  line-height: 72rpx;
  font-weight: 800;
}

.size-tab-active {
  background: #7dd7c2;
  color: #10201d;
}

.board {
  margin: 26rpx auto 0;
  width: 100%;
  max-width: 694rpx;
  height: 694rpx;
  max-height: 694rpx;
  aspect-ratio: 1 / 1;
  box-sizing: border-box;
  display: grid;
  gap: 10rpx;
  grid-auto-columns: minmax(0, 1fr);
  grid-auto-rows: minmax(0, 1fr);
  overflow: hidden;
}

.cell {
  min-width: 0;
  min-height: 0;
  box-sizing: border-box;
  aspect-ratio: 1 / 1;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  background: #17231f;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  color: #ffffff;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 900;
}

.board-size-4 .cell {
  font-size: 38rpx;
}

.board-size-6 {
  gap: 8rpx;
}

.board-size-6 .cell {
  border-radius: 11rpx;
  font-size: 30rpx;
}

.cell-next {
  border-color: rgba(241, 163, 108, 0.7);
}

.cell-done {
  background: #21342f;
  border-color: rgba(125, 215, 194, 0.3);
}

.bottom-bar {
  margin-top: 22rpx;
  min-height: 74rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.hint {
  min-width: 0;
  flex: 1;
  font-size: 26rpx;
  line-height: 1.35;
  color: rgba(244, 247, 246, 0.72);
}

.mistakes {
  flex-shrink: 0;
  padding: 12rpx 16rpx;
  border-radius: 14rpx;
  background: #201c18;
  color: #f1a36c;
  font-size: 24rpx;
  line-height: 1.2;
  font-weight: 800;
}

.rank-mask {
  position: fixed;
  inset: 0;
  z-index: 40;
  box-sizing: border-box;
  padding: 120rpx 28rpx 42rpx;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  background: rgba(5, 9, 8, 0.68);
  backdrop-filter: blur(8rpx);
}

.record-panel {
  width: 100%;
  max-height: 78vh;
  box-sizing: border-box;
  padding: 22rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  border-radius: 18rpx;
  background: #121c1a;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.record-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.record-title,
.record-status,
.record-rank,
.record-name,
.record-meta,
.record-time,
.record-empty {
  display: block;
}

.record-title {
  font-size: 30rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #ffffff;
}

.record-status {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.3;
  color: rgba(244, 247, 246, 0.56);
}

.record-refresh {
  width: 64rpx;
  height: 64rpx;
  margin: 0;
  padding: 0;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  background: #17231f;
}

.profile-card,
.mine-card {
  margin-top: 16rpx;
  min-height: 76rpx;
  box-sizing: border-box;
  padding: 14rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  border-radius: 14rpx;
  background: #17231f;
}

.profile-copy {
  min-width: 0;
  flex: 1;
}

.profile-label,
.profile-name,
.mine-label,
.mine-value {
  display: block;
}

.profile-label,
.mine-label {
  font-size: 21rpx;
  line-height: 1.2;
  color: rgba(244, 247, 246, 0.52);
  font-weight: 800;
}

.profile-name,
.mine-value {
  margin-top: 6rpx;
  font-size: 27rpx;
  line-height: 1.2;
  color: #ffffff;
  font-weight: 900;
}

.profile-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mine-value {
  margin-top: 0;
  color: #f1a36c;
}

.profile-btn,
.modal-close {
  margin: 0;
  padding: 0;
  border: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
  font-weight: 900;
}

.profile-btn {
  width: 116rpx;
  height: 58rpx;
  flex-shrink: 0;
  background: #7dd7c2;
  color: #10201d;
  font-size: 24rpx;
  line-height: 1;
}

.record-list {
  margin-top: 16rpx;
  min-height: 0;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.record-row {
  min-height: 76rpx;
  box-sizing: border-box;
  padding: 12rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  border-radius: 14rpx;
  background: #17231f;
}

.record-rank {
  width: 56rpx;
  flex-shrink: 0;
  color: #7dd7c2;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 900;
}

.record-copy {
  min-width: 0;
  flex: 1;
}

.record-name {
  font-size: 25rpx;
  line-height: 1.25;
  color: #ffffff;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-meta {
  margin-top: 6rpx;
  font-size: 21rpx;
  line-height: 1.25;
  color: rgba(244, 247, 246, 0.52);
}

.record-time {
  flex-shrink: 0;
  color: #f1a36c;
  font-size: 27rpx;
  line-height: 1;
  font-weight: 900;
}

.record-empty {
  margin-top: 16rpx;
  padding: 20rpx;
  border-radius: 14rpx;
  background: #17231f;
  color: rgba(244, 247, 246, 0.56);
  font-size: 24rpx;
  line-height: 1.35;
  text-align: center;
}

.modal-close {
  margin-top: 18rpx;
  width: 100%;
  height: 68rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #f4f7f6;
  font-size: 25rpx;
  line-height: 1;
}
