page {
  background: #0f1715;
  color: #f4f7f6;
}

.shake-page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 28rpx 28rpx 56rpx;
  background: #0f1715;
}

.tool-head {
  padding-bottom: 22rpx;
}

.kicker,
.title,
.subtitle,
.box-tag,
.box-title,
.box-text,
.status-text,
.history-title,
.history-clear,
.history-tag,
.history-name {
  display: block;
}

.kicker {
  font-size: 21rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #f1a36c;
  letter-spacing: 0;
}

.title {
  margin-top: 8rpx;
  font-size: 46rpx;
  line-height: 1.12;
  font-weight: 900;
  color: #ffffff;
}

.subtitle {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.45;
  color: rgba(244, 247, 246, 0.66);
}

.box-stage {
  min-height: 460rpx;
  box-sizing: border-box;
  padding: 42rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  border-radius: 16rpx;
  background: #141f1d;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.box-stage-open {
  border-color: rgba(241, 163, 108, 0.36);
}

.box-icon {
  width: 138rpx;
  height: 138rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: #f1a36c;
}

.box-tag {
  margin-top: 28rpx;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  background: rgba(125, 215, 194, 0.14);
  color: #7dd7c2;
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 800;
}

.box-title {
  margin-top: 22rpx;
  max-width: 560rpx;
  font-size: 36rpx;
  line-height: 1.24;
  font-weight: 900;
  color: #ffffff;
}

.box-text {
  margin-top: 16rpx;
  max-width: 560rpx;
  font-size: 26rpx;
  line-height: 1.55;
  color: rgba(244, 247, 246, 0.68);
}

.actions {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: 1fr 220rpx;
  gap: 14rpx;
}

.primary-btn,
.ghost-btn {
  min-height: 82rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border-radius: 16rpx;
  font-size: 27rpx;
  line-height: 1.2;
  font-weight: 800;
}

.primary-btn {
  background: #7dd7c2;
  color: #10201d;
}

.ghost-btn {
  background: #182421;
  color: #f4f7f6;
}

.primary-btn::after,
.ghost-btn::after {
  border: 0;
}

.status-row {
  margin-top: 16rpx;
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.status-text {
  font-size: 23rpx;
  line-height: 1.35;
  color: rgba(244, 247, 246, 0.55);
}

.history {
  margin-top: 32rpx;
  overflow: hidden;
  border-radius: 16rpx;
  background: #121c1a;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.history-head,
.history-row {
  min-height: 86rpx;
  box-sizing: border-box;
  padding: 18rpx 22rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.history-row:last-child {
  border-bottom: 0;
}

.history-title {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #ffffff;
}

.history-clear {
  font-size: 24rpx;
  line-height: 1.2;
  color: #f1a36c;
}

.history-tag {
  width: 140rpx;
  flex-shrink: 0;
  font-size: 23rpx;
  line-height: 1.2;
  color: #7dd7c2;
  font-weight: 800;
}

.history-name {
  min-width: 0;
  flex: 1;
  font-size: 25rpx;
  line-height: 1.32;
  color: rgba(244, 247, 246, 0.78);
}
