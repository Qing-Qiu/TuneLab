page {
  height: 100%;
  background: #f5f7f8;
  color: #172724;
}

button {
  font: inherit;
}

button::after {
  border: 0;
}

.page-container {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
  background: #f5f7f8;
}

.background-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 520rpx;
  background: linear-gradient(180deg, #edf7f3 0%, rgba(245, 247, 248, 0) 100%);
  pointer-events: none;
  z-index: 0;
}

.main-layout {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
  display: flex;
  flex-direction: column;
}

.custom-tabs {
  --td-tab-nav-bg-color: rgba(255, 255, 255, 0.92);
  --td-tab-item-color: #6f7c75;
  --td-tab-item-active-color: #2f6f6a;
  --td-tab-track-color: #e76545;
  --td-tab-track-width: 38rpx;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.92) !important;
  border-bottom: 1rpx solid rgba(23, 39, 36, 0.08);
  backdrop-filter: blur(18rpx);
}

.custom-tab-item {
  font-size: 30rpx;
  font-weight: 600;
  color: #6f7c75;
  letter-spacing: 0;
}

.custom-tab-active {
  color: #2f6f6a !important;
  font-size: 32rpx;
}

.content-scroll {
  flex: 1;
  width: 100%;
  height: 0;
}

.content-wrapper {
  box-sizing: border-box;
  min-height: 100%;
  padding: 24rpx 28rpx 140rpx;
}

.main-layout > .content-wrapper {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
}

.listen-hero {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 28rpx;
  padding: 28rpx 4rpx 30rpx;
  border-bottom: 1rpx solid rgba(47, 111, 106, 0.18);
}

.listen-copy {
  min-width: 0;
  display: flex;
  flex: 1;
  flex-direction: column;
}

.hero-eyebrow,
.game-kicker {
  font-size: 22rpx;
  line-height: 1.4;
  color: #e76545;
  font-weight: 700;
  letter-spacing: 0;
}

.hero-title {
  margin-top: 8rpx;
  font-size: 46rpx;
  line-height: 1.18;
  font-weight: 800;
  color: #172724;
}

.hero-subtitle {
  margin-top: 14rpx;
  max-width: 480rpx;
  font-size: 26rpx;
  line-height: 1.55;
  color: #5d6a64;
}

.hero-badge {
  box-sizing: border-box;
  width: 132rpx;
  min-height: 112rpx;
  padding: 16rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(47, 111, 106, 0.18);
  background: #ffffff;
}

.hero-badge-text {
  max-width: 100%;
  font-size: 24rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #2f6f6a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.search-container {
  position: sticky;
  top: 0;
  z-index: 5;
  padding: 20rpx 0;
  background: rgba(245, 247, 248, 0.96);
  backdrop-filter: blur(16rpx);
}

.song-list-container {
  padding: 4rpx 0 0;
}

.song-card-wrapper {
  margin-bottom: 18rpx;
}

.song-card-wrapper:active {
  transform: scale(0.99);
}

.song-card {
  box-sizing: border-box;
  min-height: 142rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(23, 39, 36, 0.08);
  background: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(23, 39, 36, 0.05);
}

.song-card-hover {
  background: #f8fbfa;
}

.song-left {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  margin-right: 18rpx;
}

.song-rank {
  width: 44rpx;
  flex-shrink: 0;
  margin-right: 12rpx;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 700;
  color: #9aa59f;
  text-align: center;
}

.song-cover {
  width: 104rpx;
  height: 104rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
  border-radius: 14rpx;
  background: #e8eeeb;
}

.song-info {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.song-title {
  width: 100%;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #172724;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.song-artist {
  width: 100%;
  margin-top: 8rpx;
  font-size: 25rpx;
  line-height: 1.35;
  color: #6f7c75;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.play-btn {
  width: 68rpx;
  height: 68rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(231, 101, 69, 0.1);
}

.loading-footer {
  min-height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.footer-text {
  font-size: 25rpx;
  color: #8b9892;
}

.game-intro-container {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.game-hero {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 4rpx 6rpx;
}

.game-hero-media {
  width: 136rpx;
  height: 136rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  border: 1rpx solid rgba(47, 111, 106, 0.16);
  background: #ffffff;
}

.game-hero-icon {
  width: 84rpx;
  height: 84rpx;
}

.game-hero-copy {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.intro-title {
  margin-top: 8rpx;
  font-size: 44rpx;
  line-height: 1.18;
  color: #172724;
  font-weight: 800;
}

.intro-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.55;
  color: #5d6a64;
}

.custom-theme-search {
  min-height: 88rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  padding: 0 22rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(23, 39, 36, 0.08);
  background: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(23, 39, 36, 0.05);
}

.theme-input {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  font-size: 29rpx;
  color: #172724;
}

.theme-placeholder {
  color: #9aa59f;
}

.singer-selection {
  width: 100%;
}

.singer-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.singer-tag {
  box-sizing: border-box;
  max-width: 100%;
  min-height: 60rpx;
  display: flex;
  align-items: center;
  padding: 0 22rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(23, 39, 36, 0.09);
  background: #ffffff;
  color: #46534e;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.2;
}

.singer-tag-active {
  color: #ffffff;
  border-color: #2f6f6a;
  background: #2f6f6a;
}

.game-actions {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 8rpx;
}

.action-row {
  display: flex;
  gap: 18rpx;
}

.pk-btn,
.join-btn {
  flex: 1;
  min-width: 0;
}

.start-btn,
.pk-btn,
.join-btn,
.restart-btn {
  min-height: 92rpx !important;
  border-radius: 16rpx !important;
  font-weight: 700 !important;
  font-size: 30rpx !important;
}

.start-btn,
.restart-btn {
  background: #e76545 !important;
  border-color: #e76545 !important;
}

.pk-btn {
  background: #2f6f6a !important;
  border-color: #2f6f6a !important;
}

.join-btn {
  color: #2f6f6a !important;
  background: #ffffff !important;
  border: 1rpx solid rgba(47, 111, 106, 0.24) !important;
}

.dialog-input-wrapper {
  padding: 18rpx 0 4rpx;
  background: transparent;
}

.dialog-input {
  min-height: 84rpx;
  border-radius: 16rpx;
  background: #f5f7f8;
  padding: 0 18rpx;
}

.lobby-container,
.game-result-container {
  min-height: 100%;
  display: flex;
  flex-direction: column;
}

.lobby-container {
  gap: 28rpx;
}

.lobby-header,
.game-header {
  min-height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.lobby-title {
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #172724;
}

.room-id-container {
  min-height: 92rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  border-radius: 16rpx;
  border: 1rpx dashed rgba(47, 111, 106, 0.42);
  background: rgba(255, 255, 255, 0.78);
}

.room-id-label {
  font-size: 27rpx;
  color: #6f7c75;
}

.room-id-text {
  font-size: 38rpx;
  line-height: 1;
  font-weight: 800;
  color: #2f6f6a;
}

.lobby-players {
  display: flex;
  align-items: stretch;
  gap: 16rpx;
}

.player-card {
  box-sizing: border-box;
  min-width: 0;
  flex: 1;
  min-height: 280rpx;
  padding: 28rpx 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  border: 1rpx solid rgba(23, 39, 36, 0.08);
  background: #ffffff;
}

.player-name {
  max-width: 100%;
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #172724;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.player-status {
  margin-top: 10rpx;
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  line-height: 1.2;
  color: #6f7c75;
  background: #eef2f0;
}

.player-status.ready {
  color: #ffffff;
  background: #2f6f6a;
}

.player-status.waiting {
  color: #9b6533;
  background: #fff2dc;
}

.waiting-avatar {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #edf2ef;
}

.vs-divider,
.vs-badge {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  color: #e76545;
}

.vs-divider {
  width: 58rpx;
  font-size: 24rpx;
}

.lobby-actions {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.invite-btn {
  min-height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: #2f6f6a;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.2;
}

.waiting-text,
.waiting-next {
  font-size: 26rpx;
  line-height: 1.4;
  color: #6f7c75;
  text-align: center;
}

.game-play-container {
  min-height: 100%;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.header-left,
.header-right {
  width: 92rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.round-indicator {
  min-width: 0;
  flex: 1;
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 800;
  color: #172724;
  text-align: center;
}

.score-indicator {
  min-width: 64rpx;
  height: 64rpx;
  padding: 0 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: #2f6f6a;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
}

.opponent-color {
  background: #e76545;
}

.pk-score-bar {
  position: relative;
  min-height: 54rpx;
  display: flex;
  overflow: hidden;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid rgba(23, 39, 36, 0.08);
}

.opponent-score,
.my-score {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 48rpx;
  font-size: 24rpx;
  font-weight: 800;
  color: #ffffff;
}

.opponent-score {
  background: #e76545;
}

.my-score {
  background: #2f6f6a;
}

.vs-badge {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 56rpx;
  height: 38rpx;
  margin-left: -28rpx;
  margin-top: -19rpx;
  border-radius: 12rpx;
  background: #ffffff;
  font-size: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(23, 39, 36, 0.12);
}

.vinyl-container {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 26rpx 0 16rpx;
}

.vinyl-disc {
  position: relative;
  width: 420rpx;
  height: 420rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: radial-gradient(circle at center, #26312e 0 12%, #172724 13% 33%, #26312e 34% 36%, #0f1715 37% 58%, #26312e 59% 61%, #0f1715 62% 100%);
  box-shadow: 0 18rpx 38rpx rgba(23, 39, 36, 0.18);
}

.vinyl-cover {
  width: 154rpx;
  height: 154rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #e76545;
  box-shadow: inset 0 0 0 10rpx rgba(255, 255, 255, 0.18);
}

.vinyl-playing .vinyl-disc {
  animation: vinylSpin 5s linear infinite;
}

.options-container {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.option-btn {
  width: 100%;
  min-height: 94rpx;
  box-sizing: border-box;
  padding: 0 22rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(23, 39, 36, 0.08);
  background: #ffffff;
  color: #172724;
  box-shadow: 0 8rpx 20rpx rgba(23, 39, 36, 0.05);
}

.option-btn:active {
  background: #f8fbfa;
}

.option-content {
  min-height: 94rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.option-text {
  min-width: 0;
  flex: 1;
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 700;
  text-align: left;
  color: inherit;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.option-correct {
  color: #ffffff;
  border-color: #2f6f6a;
  background: #2f6f6a;
}

.option-wrong {
  color: #ffffff;
  border-color: #e76545;
  background: #e76545;
}

.game-result-container {
  align-items: center;
  justify-content: center;
  padding: 42rpx 0;
}

.result-card {
  box-sizing: border-box;
  width: 100%;
  padding: 42rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-radius: 16rpx;
  border: 1rpx solid rgba(23, 39, 36, 0.08);
  background: #ffffff;
  box-shadow: 0 14rpx 34rpx rgba(23, 39, 36, 0.08);
}

.result-title {
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #172724;
}

.result-score {
  margin-top: 20rpx;
  font-size: 76rpx;
  line-height: 1;
  font-weight: 800;
  color: #e76545;
}

.opponent-result-score {
  font-size: 24rpx;
  color: #6f7c75;
}

.result-desc {
  min-height: 54rpx;
  margin: 28rpx 0 34rpx;
  font-size: 28rpx;
  line-height: 1.45;
  color: #5d6a64;
  text-align: center;
}

.back-to-intro {
  margin-top: 28rpx;
  font-size: 28rpx;
  line-height: 1.4;
  color: #2f6f6a;
  font-weight: 700;
}

.animate-enter {
  opacity: 0;
  animation: slideInUp 0.38s ease forwards;
}

@keyframes slideInUp {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes vinylSpin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

.landscape-mode .content-wrapper {
  padding: 14rpx 28rpx 28rpx;
}

.landscape-mode .custom-tabs {
  display: none;
}

.landscape-mode .game-play-container {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 14rpx 28rpx;
  align-items: center;
  min-height: 100vh;
}

.landscape-mode .game-header,
.landscape-mode .pk-score-bar {
  width: 100%;
  flex: 0 0 100%;
}

.landscape-mode .vinyl-container {
  width: 42%;
  flex: 0 0 42%;
  padding: 0;
}

.landscape-mode .vinyl-disc {
  width: 310rpx;
  height: 310rpx;
}

.landscape-mode .vinyl-cover {
  width: 116rpx;
  height: 116rpx;
}

.landscape-mode .options-container {
  min-width: 0;
  flex: 1;
  gap: 12rpx;
}

.landscape-mode .option-btn,
.landscape-mode .option-content {
  min-height: 74rpx;
}

.hero-eyebrow,
.hero-title,
.hero-subtitle,
.hero-badge-text,
.game-kicker,
.intro-title,
.intro-desc,
.song-rank,
.song-title,
.song-artist,
.footer-text,
.room-id-label,
.room-id-text,
.player-name,
.player-status,
.round-indicator,
.result-title,
.result-score,
.opponent-result-score,
.result-desc,
.back-to-intro,
.waiting-text,
.waiting-next {
  display: block;
}

/* 2026 redesign */
page {
  background: #0f1715;
  color: #f4f7f6;
}

.page-container {
  background: #0f1715;
}

.background-bg {
  height: 720rpx;
  background:
    radial-gradient(circle at top right, rgba(239, 145, 104, 0.28), transparent 34%),
    radial-gradient(circle at top left, rgba(98, 179, 159, 0.26), transparent 38%),
    linear-gradient(180deg, #11201d 0%, #0f1715 72%);
}

.music-skin .background-bg {
  background:
    radial-gradient(circle at top right, rgba(239, 145, 104, 0.24), transparent 32%),
    radial-gradient(circle at 18% 0%, rgba(98, 179, 159, 0.22), transparent 42%),
    linear-gradient(180deg, #102421 0%, #0f1715 72%);
}

.quiz-skin .background-bg {
  background:
    radial-gradient(circle at top right, rgba(241, 97, 78, 0.22), transparent 32%),
    radial-gradient(circle at 18% 0%, rgba(55, 126, 115, 0.26), transparent 42%),
    linear-gradient(180deg, #131d1a 0%, #0f1715 74%);
}

.playing-skin .background-bg {
  background:
    radial-gradient(circle at top center, rgba(241, 97, 78, 0.16), transparent 28%),
    radial-gradient(circle at 18% 12%, rgba(55, 126, 115, 0.24), transparent 36%),
    linear-gradient(180deg, #0d1412 0%, #090d0c 100%);
}

.custom-tabs {
  --td-tab-nav-bg-color: rgba(11, 19, 17, 0.72);
  --td-tab-item-color: rgba(217, 228, 224, 0.68);
  --td-tab-item-active-color: #f4f7f6;
  --td-tab-track-color: #f1a36c;
  background: rgba(9, 14, 13, 0.62) !important;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(20rpx);
}

.custom-tab-item {
  color: rgba(217, 228, 224, 0.68);
  font-weight: 600;
}

.custom-tab-active {
  color: #f4f7f6 !important;
  font-size: 32rpx;
}

.content-wrapper {
  padding: 28rpx 28rpx 160rpx;
}

.music-view,
.quiz-view {
  color: #f4f7f6;
}

.music-view {
  padding-bottom: 360rpx;
}

.eyebrow-label,
.section-kicker,
.hero-stat-label,
.quiz-metric-label,
.room-meta-label,
.room-banner-label,
.hud-score-label,
.pk-score-label {
  display: block;
  font-size: 21rpx;
  line-height: 1.3;
  letter-spacing: 0;
  color: rgba(237, 244, 242, 0.72);
}

.section-header {
  display: flex;
  flex-direction: column;
}

.section-title {
  display: block;
  margin-top: 6rpx;
  font-size: 38rpx;
  line-height: 1.16;
