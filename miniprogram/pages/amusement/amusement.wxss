  top: 28rpx;
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(241, 163, 108, 0.22) 0%, rgba(241, 163, 108, 0) 68%);
  filter: blur(8rpx);
}

.vinyl-container {
  position: relative;
  z-index: 1;
  width: 360rpx;
  height: 360rpx;
  padding: 0;
}

.vinyl-disc {
  width: 360rpx;
  height: 360rpx;
  background: radial-gradient(circle at center, #2a3935 0 12%, #182320 13% 34%, #27312f 35% 38%, #0d1412 39% 61%, #293734 62% 64%, #08100e 65% 100%);
