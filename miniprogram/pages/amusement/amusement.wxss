  padding: 40rpx 28rpx;
  border-radius: 16rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.08) 0%, rgba(241, 163, 108, 0.08) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: none;
}

