  font-size: 28rpx;
  line-height: 1.5;
}

.back-to-intro {
  margin-top: 24rpx;
  text-align: center;
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #f1d6b8;
}

.animate-enter {
  opacity: 0;
  animation: slideLift 0.42s ease forwards;
}

@keyframes slideLift {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes vinylSpin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

