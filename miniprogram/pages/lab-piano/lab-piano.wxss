}

.piano-landscape .rank-filter-scroll {
  margin-top: 6rpx;
}

.piano-landscape .rank-filter-row {
  gap: 4rpx;
}

.piano-landscape .rank-filter-chip {
  height: 28rpx;
  padding: 0 10rpx;
  border-radius: 8rpx;
  font-size: 10rpx;
}

.piano-landscape .rank-modal-list {
  margin-top: 8rpx;
  gap: 6rpx;
}

.piano-landscape .rank-row {
  min-height: 52rpx;
  padding: 8rpx 9rpx;
  gap: 8rpx;
