  background: #0f1715;
}

.piano-hero,
.control-panel,
.challenge-panel,
.level-panel,
.daily-panel,
.rank-panel,
.status-item,
.keyboard-meta-item {
  border-radius: 16rpx;
  background: #121c1a;
}

.piano-hero {
  min-height: 156rpx;
  padding: 24rpx;
}

.hero-title {
  font-size: 42rpx;
}

.hero-subtitle {
  margin-top: 10rpx;
  color: rgba(244, 247, 246, 0.66);
}

.hero-actions {
  width: 88rpx;
}

.control-panel,
.challenge-panel {
  padding: 20rpx;
}

.mode-tabs {
  background: #0f1715;
}

.status-strip,
.keyboard-meta {
  gap: 10rpx;
}

.level-panel,
.daily-panel,
