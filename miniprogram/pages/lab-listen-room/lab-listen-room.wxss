page {
  background: #0f1715;
  color: #f4f7f6;
}

.listen-room-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 28rpx 56rpx;
  background:
    radial-gradient(circle at 86% 0%, rgba(241, 163, 108, 0.14), transparent 30%),
    radial-gradient(circle at 8% 12%, rgba(125, 215, 194, 0.13), transparent 28%),
    linear-gradient(180deg, #101d1a 0%, #0f1715 72%);
}

.listen-room-hero,
.room-panel,
.search-panel,
.reaction-panel {
  box-sizing: border-box;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  background: rgba(255, 255, 255, 0.06);
}

.listen-room-hero {
  min-height: 188rpx;
  padding: 30rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.08), rgba(125, 215, 194, 0.14)),
    #111c19;
}

.hero-copy {
  min-width: 0;
  flex: 1;
}

.eyebrow,
.hero-title,
.hero-subtitle,
.section-kicker,
.section-title,
.room-song-title,
.room-song-artist,
.room-state,
.player-time,
.selected-title,
.selected-artist,
.song-title,
.song-artist,
.event-type,
.event-text {
  display: block;
}

.eyebrow,
.section-kicker {
  font-size: 22rpx;
  line-height: 1.3;
  font-weight: 800;
  color: rgba(244, 247, 246, 0.62);
}

.hero-title {
  margin-top: 10rpx;
  font-size: 48rpx;
  line-height: 1.08;
  font-weight: 900;
  color: #ffffff;
}

.hero-subtitle {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.45;
  color: rgba(244, 247, 246, 0.78);
}

.hero-icon {
  width: 116rpx;
  height: 116rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: rgba(9, 14, 13, 0.42);
}

.room-panel,
.search-panel,
.reaction-panel {
  margin-top: 20rpx;
  padding: 22rpx;
}

.section-title {
  margin-top: 6rpx;
  font-size: 34rpx;
  line-height: 1.2;
  color: #ffffff;
  font-weight: 900;
}

.join-row {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: 1fr 150rpx;
  gap: 12rpx;
}

.room-input,
.search-input {
  min-width: 0;
  height: 72rpx;
  box-sizing: border-box;
  color: #ffffff;
  font-size: 25rpx;
}

.room-input {
  padding: 0 18rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.08);
}

.input-placeholder {
  color: rgba(228, 236, 233, 0.42);
}

.join-btn,
.search-btn,
.create-btn,
.create-room-btn,
.room-copy-mini,
.song-sync-mini,
.room-btn,
.control-btn,
.emoji-btn,
.quick-btn {
  margin: 0;
  padding: 0;
  border: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border-radius: 14rpx;
  font-weight: 900;
}

.join-btn::after,
.search-btn::after,
.create-btn::after,
.create-room-btn::after,
.room-copy-mini::after,
.song-sync-mini::after,
.room-btn::after,
.control-btn::after,
.emoji-btn::after,
.quick-btn::after {
  border: 0;
}

.join-btn,
.create-btn,
.search-btn,
.create-room-btn {
  height: 72rpx;
  background: #7dd7c2;
  color: #10201d;
  font-size: 24rpx;
}

.create-room-btn {
  margin-top: 14rpx;
  width: 100%;
  gap: 8rpx;
}

.room-card {
  margin-top: 18rpx;
}

.room-title-row {
  margin-top: 6rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.room-title-row .section-title {
  margin-top: 0;
}

.room-copy-mini {
  width: 48rpx;
  height: 48rpx;
  flex-shrink: 0;
  border-radius: 12rpx;
  background: #7dd7c2;
}

.room-song,
.room-empty-song,
.selected-song,
.song-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.room-empty-song {
  min-height: 108rpx;
  box-sizing: border-box;
  padding: 18rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.055);
}

.room-cover,
.selected-cover,
.song-cover {
  flex-shrink: 0;
  border-radius: 12rpx;
  background: #17231f;
}

.room-cover {
  width: 108rpx;
  height: 108rpx;
}

.room-song-copy,
.selected-copy,
.song-copy {
  min-width: 0;
  flex: 1;
}

.room-song-title,
.selected-title,
.song-title {
  color: #ffffff;
  font-size: 27rpx;
  line-height: 1.24;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.room-song-artist,
.selected-artist,
.song-artist,
.room-state {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.25;
  color: rgba(228, 236, 233, 0.62);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.room-state {
  color: #7dd7c2;
  font-weight: 800;
}

.room-actions,
.host-controls {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.room-actions-three {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.room-btn,
.control-btn {
  height: 68rpx;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #f4f7f6;
  font-size: 23rpx;
}

.room-btn-primary,
.control-play {
  background: #f1a36c;
  color: #12201d;
}

.room-btn-danger {
  background: rgba(217, 72, 65, 0.2);
  color: #f4f7f6;
}

.room-btn[disabled],
.control-btn[disabled] {
  opacity: 0.42;
}

.player-strip {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: 84rpx 1fr 84rpx;
  align-items: center;
  gap: 12rpx;
}

.player-time {
  font-size: 22rpx;
  color: rgba(228, 236, 233, 0.62);
  text-align: center;
}

.player-slider {
  margin: 0;
  min-width: 0;
}

.player-slider-active {
  opacity: 1;
}

.player-slider-view {
  opacity: 0.72;
}

.search-box {
  margin-top: 18rpx;
  min-height: 74rpx;
  padding: 0 10rpx 0 18rpx;
  box-sizing: border-box;
  display: grid;
  grid-template-columns: 34rpx 1fr 128rpx;
  align-items: center;
  gap: 10rpx;
  border-radius: 14rpx;
  background: rgba(9, 14, 13, 0.42);
}

.locked-tip {
  margin-top: 18rpx;
  min-height: 68rpx;
  box-sizing: border-box;
  padding: 14rpx 16rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  border-radius: 14rpx;
  background: rgba(241, 163, 108, 0.12);
  color: rgba(244, 247, 246, 0.72);
  font-size: 23rpx;
  line-height: 1.35;
}

.selected-song {
  margin-top: 16rpx;
  padding: 14rpx;
  border-radius: 14rpx;
  background: rgba(125, 215, 194, 0.1);
}

.selected-cover,
.song-cover {
  width: 76rpx;
  height: 76rpx;
}

.create-btn {
  width: 150rpx;
  flex-shrink: 0;
}

.song-sync-mini {
  width: 110rpx;
  height: 58rpx;
  flex-shrink: 0;
  border-radius: 12rpx;
  background: #7dd7c2;
  color: #10201d;
  font-size: 22rpx;
}

.song-sync-mini[disabled] {
  opacity: 0.48;
}

.search-list,
.event-list {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.song-row {
  min-height: 102rpx;
  box-sizing: border-box;
  padding: 12rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.055);
}

.song-row-active {
  background: rgba(125, 215, 194, 0.14);
  border: 1rpx solid rgba(125, 215, 194, 0.28);
}

.emoji-row,
.quick-row {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.emoji-btn {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.08);
  font-size: 28rpx;
}

.quick-btn {
  height: 58rpx;
  padding: 0 18rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #f4f7f6;
  font-size: 22rpx;
}

.event-row {
  min-height: 58rpx;
  padding: 10rpx 12rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 12rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.045);
}

.event-type {
  width: 70rpx;
  flex-shrink: 0;
  color: #7dd7c2;
  font-size: 20rpx;
  font-weight: 900;
}

.event-text {
  min-width: 0;
  flex: 1;
  color: rgba(244, 247, 246, 0.78);
  font-size: 22rpx;
  line-height: 1.25;
}
